{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "description": "Automated dependency updates with automerge",
  "ignorePresets": [":ignoreModulesAndTests"],
  "automerge": true,
  "platformAutomerge": false,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "custom-package-registry-test: PublishProject only exists on the fixture's private registry, not a real feed, so leave it pinned",
      "matchFileNames": ["tests/custom-package-registry-test/**"],
      "matchDepNames": ["PublishProject"],
      "enabled": false
    },
    {
      "description": "dotnet/sdk Docker images: block major updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["mcr.microsoft.com/dotnet/sdk"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "localhost images: disable entirely (test fixture)",
      "matchDatasources": ["docker"],
      "enabled": false,
      "matchPackageNames": [
        "/^localhost/"
      ]
    },
    {
      "description": "NuGet packages: block major updates",
      "matchDatasources": ["nuget"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "docker.io/spritelydev/dotnet10-devcontainer",
        "spritely/actions.semantic-version"
      ],
      "groupName": "spritely infrastructure"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions in shell scripts with renovate comments",
      "managerFilePatterns": [
        "/\\.sh$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+?)(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+[A-Z_]+?=\"\\$\\{[A-Z_]+?:-(?<currentValue>.+?)\\}\""
      ]
    }
  ]
}
